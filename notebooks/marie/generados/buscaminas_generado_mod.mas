/ ============================================================
/ BUSCAMINAS MARIE V8 - GEOMETRÍA DINÁMICA, SCORE Y MENSAJES
/ ============================================================
ORG 000
JUMP START

/ --- Variables de Juego ---
FILA,       DEC 0
COL,        DEC 0
ACCION,     DEC 0
INDEX,      DEC 0      / Índice lineal (Fila * 16 + Col)
VALOR,      DEC 0      / Valor real de la celda (-1 a 8)
DIR,        DEC 0      / Dirección de memoria calculada
COUNT,      DEC 0      / Contador para bucles
TMP,        DEC 0      / Variable temporal
GAME_STATE, DEC 0      / 0:Jugando, 1:Pierde, 2:Gana
REV_COUNT,  DEC 0      / Celdas reveladas
SCORE,      DEC 0      / Banderas correctas sobre minas
SAFE_TGT,   DEC 0      / Objetivo de celdas para ganar
CURR_REG,   DEC 0      / Región actual para expansión

/ --- Constantes ---
ZERO,       DEC 0
ONE,        DEC 1
TWO,        DEC 2
SIXTEEN,    DEC 16
MAX_CELLS,  DEC 256
ST_HIDDEN,  DEC 0
ST_REVEAL,  DEC 1
ST_FLAG,    DEC 2
MITAD,      DEC 7      / Centro del tablero para figuras
LIMITE,     DEC 8      / Tamaño de la figura

/ --- Caracteres ASCII (Líneas independientes para evitar error) ---
ASC_S, DEC 83
ASC_T, DEC 84
ASC_A, DEC 65
ASC_R, DEC 82
ASC_G, DEC 71
ASC_M, DEC 77
ASC_E, DEC 69
ASC_O, DEC 79
ASC_V, DEC 86
ASC_N, DEC 78
ASC_I, DEC 73
ASC_W, DEC 87
ASC_SPACE, DEC 32
ASC_COLON, DEC 58

/ --- Direcciones Base Estáticas ---
B_VIS,     HEX 0600
B_REAL,    HEX 0045    / Mapa real inyectado (69 en DEC)
B_REGIONS, HEX 0245    / Mapa de regiones inyectado
B_DISP,    HEX 0F00    / Pantalla 16x16

/ --- Colores ---
C_HID, HEX 0666 | C_FLG, HEX 0FF0 | C_MIN, HEX 0000 | C_OUT, HEX 0222
C_0,   HEX 0CCC | C_1,   HEX 000F | C_2,   HEX 00F0 | C_3,   HEX 0F00

